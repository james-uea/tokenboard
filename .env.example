# Tokenboard environment template.
#
# Copy this file to:
# - .env for local development
# - .env.production for Docker Compose production deployments
#
# Keep copied env files private. Replace every placeholder before exposing a
# production server.

# App URL and server port
PORT=3001
DOMAIN=tokenboard.example.com
APP_BASE_URL=http://localhost:3001

# Server secrets and authentication
SESSION_SECRET=replace-with-a-long-random-session-secret
ALLOW_LEGACY_API_KEY=false
API_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# PostgreSQL
POSTGRES_USER=tokenboard
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
POSTGRES_DB=tokenboard

# Use localhost when running the server directly on your machine.
# Use postgres as the host when running inside Docker Compose.
DATABASE_URL=postgresql://tokenboard:tokenboard@localhost:5432/tokenboard

# Optional Cloudflare Tunnel deployment.
# docker-compose.prod.yml starts a cloudflared service and requires this token.
CLOUDFLARE_TUNNEL_TOKEN=

# Reverse proxy and production hardening
TRUST_PROXY=1
TRUST_CLOUDFLARE_HEADERS=true
FORCE_HTTPS=true
JSON_BODY_LIMIT=256kb
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT=600
AUTH_RATE_LIMIT=60
CLI_POLL_RATE_LIMIT=180
SUBMIT_RATE_LIMIT=60
GITHUB_PROXY_RATE_LIMIT=120

# Optional encrypted PostgreSQL backups to an S3-compatible bucket.
# These are only required when running scripts/backup.sh or scripts/restore.sh.
BACKUP_PASSPHRASE=
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
# Optional for AWS S3. Required for Cloudflare R2 and most S3-compatible providers.
S3_ENDPOINT_URL=
S3_BUCKET=
S3_PREFIX=postgres
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

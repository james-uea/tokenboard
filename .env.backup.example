# Optional offsite backups.
# The backup scripts also load .env.production for Postgres and Compose settings.

BACKUP_PASSPHRASE=replace-with-a-long-random-backup-passphrase
BACKUP_DIR=/opt/tokenboard/backups

# Cloudflare R2
R2_BUCKET=tokenboard-backups
R2_PREFIX=postgres
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

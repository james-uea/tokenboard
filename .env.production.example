# Public URL
DOMAIN=tokenboard.example.com
APP_BASE_URL=https://tokenboard.example.com

# Cloudflare Tunnel
# Create a remotely managed tunnel in Cloudflare Zero Trust and paste its token here.
CLOUDFLARE_TUNNEL_TOKEN=

# Server secrets
SESSION_SECRET=replace-with-a-long-random-secret
API_KEY=
ALLOW_LEGACY_API_KEY=false

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# PostgreSQL
POSTGRES_USER=tokenboard
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
POSTGRES_DB=tokenboard

# Reverse proxy / Cloudflare hardening
TRUST_PROXY=1
TRUST_CLOUDFLARE_HEADERS=true
FORCE_HTTPS=true
JSON_BODY_LIMIT=256kb
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT=600
AUTH_RATE_LIMIT=60
CLI_POLL_RATE_LIMIT=180
SUBMIT_RATE_LIMIT=60
GITHUB_PROXY_RATE_LIMIT=120
